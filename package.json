{
    "name": "geospatial-toolset",
    "displayName": "Geospatial Toolset Pro",
    "description": "Professional Earth Engine helper, multi-format GIS visualizer, and live coordinate drawer.",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Visualization",
        "Data Science",
        "Snippets"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "geospatial-toolset.previewGeospatial",
                "title": "Preview Geospatial File on Map"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "when": "resourceExtname == .geojson || resourceExtname == .json || resourceExtname == .kml || resourceExtname == .wkt",
                    "command": "geospatial-toolset.previewGeospatial",
                    "group": "navigation"
                }
            ]
        },
        "snippets": [
            {
                "language": "javascript",
                "path": "./snippets/ee-snippets.json"
            },
            {
                "language": "python",
                "path": "./snippets/ee-snippets.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "npm run check-types && node esbuild.js --production",
        "check-types": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.85.0",
        "@types/wellknown": "^0.5.8",
        "esbuild": "^0.28.1",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@tmcw/togeojson": "^7.1.2",
        "@xmldom/xmldom": "^0.9.10",
        "wellknown": "^0.5.0"
    }
}
