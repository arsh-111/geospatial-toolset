{
    "Earth Engine Random Forest LULC": {
        "prefix": "ee-lulc-randomforest",
        "body": [
            "// Earth Engine Multi-Temporal LULC Classification Workflow",
            "// 1. Define Region of Interest (ROI)",
            "var roi = ee.Geometry.Rectangle([${1:74.5}, ${2:16.8}, ${3:74.7}, ${4:17.0}]);",
            "Map.centerObject(roi, 12);",
            "",
            "// 2. Load and Filter Sentinel-2 Imagery",
            "var image = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')",
            "  .filterBounds(roi)",
            "  .filterDate('${5:2025-01-01}', '${6:2025-12-31}')",
            "  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 10))",
            "  .median()",
            "  .clip(roi);",
            "",
            "// 3. Compute Spectral Indices (NDVI & NDBI)",
            "var ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI');",
            "var ndbi = image.normalizedDifference(['B11', 'B8']).rename('NDBI');",
            "var composite = image.addBands([ndvi, ndbi]);",
            "",
            "// 4. Training Data Configuration (Assuming 'training_samples' feature collection exists)",
            "var bands = ['B2', 'B3', 'B4', 'B8', 'B11', 'NDVI', 'NDBI'];",
            "var training = composite.select(bands).sampleRegions({",
            "  collection: ${7:training_samples},",
            "  properties: ['${8:landcover_class}'],",
            "  scale: 10",
            "});",
            "",
            "// 5. Train Random Forest Classifier",
            "var classifier = ee.Classifier.smileRandomForest(100).train({",
            "  features: training,",
            "  classProperty: '${8:landcover_class}',",
            "  inputProperties: bands",
            "});",
            "",
            "// 6. Classify and Display",
            "var classified = composite.select(bands).classify(classifier);",
            "Map.addLayer(image, {bands: ['B4', 'B3', 'B2'], max: 3000}, 'True Color');",
            "Map.addLayer(classified, {min: 0, max: 4, palette: ['blue', 'green', 'yellow', 'red']}, 'LULC Classified');"
        ],
        "description": "Generates a comprehensive boilerplate code block for Earth Engine Random Forest LULC classification using Sentinel-2 with NDVI/NDBI bands."
    }
}